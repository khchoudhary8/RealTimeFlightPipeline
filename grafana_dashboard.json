{
  "dashboard": {
    "title": "Flight Pipeline Monitoring",
    "uid": "flight-pipeline-dashboard",
    "version": 1,
    "timezone": "browser",
    "schemaVersion": 36,
    "panels": [
      {
        "id": 1,
        "title": "Flights Fetched per Batch",
        "type": "stat",
        "targets": [
          {
            "expr": "flights_fetched_total",
            "legendFormat": "Total Fetched",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 80 }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 2,
        "title": "Flights Sent to Kafka",
        "type": "stat",
        "targets": [
          {
            "expr": "flights_sent_total",
            "legendFormat": "Total Sent",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "title": "Processing Lag",
        "type": "gauge",
        "targets": [
          {
            "expr": "processing_lag_seconds",
            "legendFormat": "Lag (s)",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 30 }
              ]
            },
            "unit": "s",
            "min": 0,
            "max": 60
          }
        },
        "options": {
          "orientation": "auto",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          }
        }
      },
      {
        "id": 4,
        "title": "API Errors by Type",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(api_errors_total[5m])",
            "legendFormat": "{{error_type}}",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "title": "Fetch Duration",
        "type": "graph",
        "targets": [
          {
            "expr": "fetch_duration_seconds",
            "legendFormat": "Duration (p50)",
            "refId": "E"
          },
          {
            "expr": "fetch_duration_seconds_max",
            "legendFormat": "Max",
            "refId": "F"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Seconds" },
          { "format": "short" }
        ]
      },
      {
        "id": 6,
        "title": "Flights per Batch Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "flights_per_batch",
            "legendFormat": "Batch count",
            "refId": "G"
          }
        ],
        "yaxes": [
          { "format": "short", "label": "Count" },
          { "format": "short" }
        ]
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "6h", "12h", "1d"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    }
  },
  "overwrite": true
}
